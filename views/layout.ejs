<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | UKM Taekwondo UPNVJ</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
  <style>
    :root { --primary: #064e3b; --accent: #f59e0b; }
    body { background: #f8fafc; }
    .bg-primary-custom { background: var(--primary); }
    .text-accent { color: var(--accent); }
    .btn-accent { background: var(--accent); color: #000; border: none; }
    .btn-accent:hover { background: #d97706; color: #fff; }
  </style>
</head>
<body>
  <%- include('partials/header') %>
  <main class="container py-4">
    <%- body %>
  </main>
  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>