<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - UKM Taekwondo UPNVJ</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
  <style>
    body {
      background: linear-gradient(135deg, #064e3b 0%, #10b981 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .login-card {
      background: white;
      border-radius: 15px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.2);
      padding: 40px;
      max-width: 450px;
      width: 100%;
    }
    .nav-tabs .nav-link {
      color: #064e3b;
      font-weight: 500;
    }
    .nav-tabs .nav-link.active {
      color: #064e3b;
      font-weight: bold;
      border-color: #dee2e6 #dee2e6 #fff;
    }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="text-center mb-4">
      <i class="bi bi-shield-lock fs-1 text-success"></i>
      <h3 class="fw-bold mt-2">Login</h3>
      <p class="text-muted">UKM Taekwondo UPN Veteran Jakarta</p>
    </div>

    <% if (typeof success_msg !== 'undefined' && success_msg) { %>
      <div class="alert alert-success"><%= success_msg %></div>
    <% } %>
    <% if (typeof error_msg !== 'undefined' && error_msg) { %>
      <div class="alert alert-danger"><%= error_msg %></div>
    <% } %>

    <!-- Tab Navigasi -->
    <ul class="nav nav-tabs mb-3" id="loginTab" role="tablist">
      <li class="nav-item" role="presentation">
        <button class="nav-link active" id="umum-tab" data-bs-toggle="tab" data-bs-target="#umum" type="button" role="tab">
          <i class="bi bi-person me-1"></i>Login Umum
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link" id="admin-tab" data-bs-toggle="tab" data-bs-target="#admin" type="button" role="tab">
          <i class="bi bi-shield-lock me-1"></i>Admin
        </button>
      </li>
    </ul>

    <div class="tab-content" id="loginTabContent">
      <!-- Tab Login Umum (Untuk Anggota) -->
      <div class="tab-pane fade show active" id="umum" role="tabpanel">
        <form action="/login" method="POST">
          <div class="mb-3">
            <label class="form-label fw-bold">Email</label>
            <input type="email" name="identifier" class="form-control" placeholder="nama@email.com" required>
            <div class="form-text">Masukkan email yang terdaftar sebagai anggota</div>
          </div>

          <div class="mb-3">
            <label class="form-label fw-bold">Password</label>
            <input type="password" name="password" class="form-control" placeholder="••••••••" required>
          </div>

          <button type="submit" class="btn btn-success w-100 py-2 fw-bold">
            <i class="bi bi-box-arrow-in-right me-2"></i>Login Sebagai Anggota
          </button>
        </form>

        <hr class="my-4">

        <div class="text-center">
          <p class="mb-2 text-muted">Belum punya akun?</p>
          <a href="/anggota/register" class="btn btn-outline-success w-100">
            <i class="bi bi-person-plus me-2"></i>Registrasi Akun
          </a>
        </div>
      </div>

      <!-- Tab Login Admin -->
      <div class="tab-pane fade" id="admin" role="tabpanel">
        <form action="/login" method="POST">
          <div class="mb-3">
            <label class="form-label fw-bold">Username</label>
            <input type="text" name="identifier" class="form-control" placeholder="admin" required>
            <div class="form-text">Masukkan username admin</div>
          </div>

          <div class="mb-3">
            <label class="form-label fw-bold">Password</label>
            <input type="password" name="password" class="form-control" placeholder="••••••••" required>
          </div>

          <button type="submit" class="btn btn-primary w-100 py-2 fw-bold">
            <i class="bi bi-shield-check me-2"></i>Login Sebagai Admin
          </button>
        </form>

        <div class="alert alert-info mt-3 small">
          <i class="bi bi-info-circle me-1"></i>
          Hanya administrator yang memiliki akses ke panel ini.
        </div>
      </div>
    </div>

    <div class="text-center mt-4">
      <a href="/" class="text-decoration-none text-muted small">
        <i class="bi bi-arrow-left me-1"></i>Kembali ke Beranda
      </a>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
