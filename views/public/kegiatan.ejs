<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Kegiatan - UKM Taekwondo UPNVJ</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
  <style>
    .kegiatan-card { transition: transform 0.3s; }
    .kegiatan-card:hover { transform: translateY(-5px); }
    .kegiatan-img { width: 100%; height: 200px; object-fit: cover; border-radius: 8px; }
  </style>
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-success">
    <div class="container">
      <a class="navbar-brand fw-bold d-flex align-items-center" href="/">
        <img src="/uploads/logo-taveja.png" alt="Logo TAVEJA" height="40" class="me-2"> 
        TAVEJA
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto align-items-center">
          <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
          <li class="nav-item"><a class="nav-link" href="/anggota">Anggota</a></li>
          <li class="nav-item"><a class="nav-link" href="/jadwal">Jadwal</a></li>
          <li class="nav-item"><a class="nav-link" href="/kegiatan">Kegiatan</a></li>
          <li class="nav-item"><a class="nav-link" href="/prestasi">Prestasi</a></li>
          
          <!-- MENU ANGGOTA (Login/Logout) -->
          <li class="nav-item ms-2">
            <% if (typeof user !== 'undefined' && user.isLoggedIn) { %>
              <div class="dropdown">
                <button class="btn btn-light dropdown-toggle btn-sm" type="button" 
                        data-bs-toggle="dropdown" aria-expanded="false">
                  <i class="bi bi-person-circle me-1"></i><%= user.anggotaNama %>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                  <li><a class="dropdown-item" href="/kegiatan">Kegiatan</a></li>
                  <li><hr class="dropdown-divider"></li>
                  <li><a class="dropdown-item text-danger" href="/logout">Logout</a></li>
                </ul>
              </div>
            <% } else { %>
              <a href="/login" class="btn btn-light text-success btn-sm fw-bold">
                <i class="bi bi-box-arrow-in-right me-1"></i>Login Anggota
              </a>
            <% } %>
          </li>
          
          <!-- Login Admin -->
          <li class="nav-item ms-2">
            <a href="/login" class="btn btn-outline-light btn-sm">Login</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Content -->
  <div class="container py-5">
    <div class="text-center mb-5">
      <h2 class="fw-bold text-success">📅 Kegiatan Kami</h2>
      <p class="lead text-muted">Berbagai kegiatan UKM Taekwondo UPNVJ</p>
    </div>

    <% if (typeof kegiatan !== 'undefined' && kegiatan.length > 0) { %>
      <div class="row g-4">
        <% kegiatan.forEach(function(k) { %>
          <div class="col-md-6 col-lg-4">
            <div class="card h-100 border-0 shadow-sm kegiatan-card">
              <% if (k.foto) { %>
                <img src="/uploads/kegiatan/foto/<%= k.foto %>" class="card-img-top kegiatan-img" alt="<%= k.nama_kegiatan %>">
              <% } else { %>
                <div class="bg-success text-white d-flex align-items-center justify-content-center" style="height: 200px;">
                  <i class="bi bi-calendar-event display-1"></i>
                </div>
              <% } %>
              <div class="card-body">
                <span class="badge bg-info mb-2"><%= k.jenis %></span>
                <h5 class="card-title fw-bold"><%= k.nama_kegiatan %></h5>
                <p class="card-text text-muted small">
                  <i class="bi bi-calendar3 me-1"></i> <%= new Date(k.tanggal).toLocaleDateString('id-ID') %><br>
                  <i class="bi bi-geo-alt me-1"></i> <%= k.lokasi %>
                </p>
                <a href="/kegiatan/detail/<%= k.id_kegiatan %>" class="btn btn-success btn-sm">
                  Selengkapnya →
                </a>
              </div>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="text-center py-5">
        <i class="bi bi-calendar-x display-1 text-muted"></i>
        <h4 class="mt-3 text-muted">Belum Ada Kegiatan</h4>
        <p class="text-muted">Kegiatan akan segera ditampilkan</p>
      </div>
    <% } %>
  </div>

  <!-- Footer -->
  <footer class="bg-dark text-white text-center py-3 mt-auto">
    <small>© <%= new Date().getFullYear() %> UKM Taekwondo UPN Veteran Jakarta</small>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>