<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= kegiatan.nama_kegiatan %> - UKM Taekwondo UPNVJ</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
  <style>
    .detail-img { width: 100%; max-height: 400px; object-fit: cover; border-radius: 8px; }
  </style>
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-success">
    <div class="container">
        <a class="navbar-brand fw-bold d-flex align-items-center" href="/">
            <!-- Placeholder untuk logo -->
            <img src="/uploads/logo-taveja.png" alt="Logo" height="40" class="me-2"> 
            TAVEJA
        </a>
      <ul class="navbar-nav ms-auto">
        <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
        <li class="nav-item"><a class="nav-link" href="/anggota">Anggota</a></li>
        <li class="nav-item"><a class="nav-link" href="/jadwal">Jadwal</a></li>
        <li class="nav-item"><a class="nav-link active" href="/kegiatan">Kegiatan</a></li>
        <li class="nav-item"><a class="nav-link" href="/prestasi">Prestasi</a></li>
        <li class="nav-item ms-2">
          <a class="btn btn-light text-success btn-sm" href="/login">Login</a>
        </li>
      </ul>
    </div>
  </nav>

  <!-- Content -->
  <div class="container py-5">
    <a href="/kegiatan" class="btn btn-outline-secondary btn-sm mb-3">← Kembali</a>
    
    <div class="row">
      <div class="col-lg-8">
        <div class="card border-0 shadow-sm mb-4">
          <% if (kegiatan.foto) { %>
            <img src="/uploads/kegiatan/foto/<%= kegiatan.foto %>" class="card-img-top detail-img" alt="<%= kegiatan.nama_kegiatan %>">
          <% } %>
          <div class="card-body p-4">
            <span class="badge bg-info mb-2"><%= kegiatan.jenis %></span>
            <h2 class="fw-bold mb-3"><%= kegiatan.nama_kegiatan %></h2>
            
            <div class="row mb-4">
              <div class="col-md-6">
                <p class="mb-2"><i class="bi bi-calendar3 text-success me-2"></i><strong>Tanggal:</strong><br>
                <%= new Date(kegiatan.tanggal).toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %></p>
              </div>
              <div class="col-md-6">
                <p class="mb-2"><i class="bi bi-geo-alt text-success me-2"></i><strong>Lokasi:</strong><br>
                <%= kegiatan.lokasi %></p>
              </div>
            </div>

            <h5 class="fw-bold mb-3">Deskripsi Kegiatan</h5>
            <p class="text-muted"><%= kegiatan.deskripsi || 'Tidak ada deskripsi' %></p>

            <% if (kegiatan.file_penjelasan) { %>
              <div class="alert alert-light border mt-4">
                <h6 class="fw-bold"><i class="bi bi-file-earmark-text me-2"></i>Dokumen Penjelasan</h6>
                <p class="mb-2 small text-muted">Download file penjelasan lengkap kegiatan ini:</p>
                <a href="/uploads/kegiatan/file/<%= kegiatan.file_penjelasan %>" class="btn btn-primary btn-sm" download target="_blank">
                  <i class="bi bi-download me-1"></i> Download File
                </a>
              </div>
            <% } %>
          </div>
        </div>
      </div>

      <!-- Sidebar Pendaftaran -->
      <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
          <div class="card-body p-4">
            <h5 class="fw-bold mb-3">📝 Pendaftaran</h5>
            
            <% if (kegiatan.ada_pendaftaran) { %>
              
              <% if (sudahDaftar) { %>
                <div class="alert alert-success">
                  <i class="bi bi-check-circle me-2"></i>Anda sudah terdaftar di kegiatan ini!
                </div>
              <% } else if (isAnggota) { %>
                
                <% if (kegiatan.link_pendaftaran) { %>
                  <p class="small text-muted mb-3">Klik tombol di bawah untuk mendaftar:</p>
                  <a href="<%= kegiatan.link_pendaftaran %>" target="_blank" class="btn btn-success w-100 mb-2">
                    <i class="bi bi-box-arrow-up-right me-2"></i>Buka Formulir Pendaftaran
                  </a>
                  <form action="/kegiatan/daftar/<%= kegiatan.id_kegiatan %>" method="POST">
                    <button type="submit" class="btn btn-outline-success w-100">
                      <i class="bi bi-check-circle me-2"></i>Konfirmasi Pendaftaran
                    </button>
                  </form>
                <% } else { %>
                  <form action="/kegiatan/daftar/<%= kegiatan.id_kegiatan %>" method="POST">
                    <button type="submit" class="btn btn-success w-100">
                      <i class="bi bi-person-plus me-2"></i>Daftar Sekarang
                    </button>
                  </form>
                <% } %>
                
              <% } else { %>
                <div class="alert alert-warning">
                  <i class="bi bi-exclamation-triangle me-2"></i>
                  <strong>Hanya anggota yang bisa mendaftar!</strong>
                </div>
                <p class="small text-muted mb-3">Silakan login dengan akun anggota Anda untuk mendaftar kegiatan ini.</p>
                <a href="/login" class="btn btn-outline-primary w-100">
                  <i class="bi bi-box-arrow-in-right me-2"></i>Login Anggota
                </a>
              <% } %>

            <% } else { %>
              <div class="alert alert-info">
                <i class="bi bi-info-circle me-2"></i>
                Kegiatan ini tidak membuka pendaftaran. Hanya untuk informasi.
              </div>
            <% } %>

            <hr class="my-4">
            
            <div class="small text-muted">
              <p class="mb-1"><strong>Jenis:</strong> <%= kegiatan.jenis %></p>
              <p class="mb-0"><strong>Status:</strong> 
                <%= new Date(kegiatan.tanggal) > new Date() ? '<span class="text-success">Akan Datang</span>' : '<span class="text-secondary">Selesai</span>' %>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Footer -->
  <footer class="bg-dark text-white text-center py-3 mt-auto">
    <small>© <%= new Date().getFullYear() %> UKM Taekwondo UPN Veteran Jakarta</small>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>