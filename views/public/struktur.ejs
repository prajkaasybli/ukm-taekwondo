<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Struktur Organisasi - TAVEJA</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
  <style>
    .pengurus-card { transition: transform 0.3s; }
    .pengurus-card:hover { transform: translateY(-5px); }
    .pengurus-img { 
      width: 120px; 
      height: 120px; 
      object-fit: cover; 
      border-radius: 50%; 
      border: 4px solid #064e3b; 
      background: #f8f9fa;
    }
  </style>
</head>
<body>
  <!-- Navbar -->
  <nav class="navbar navbar-expand-lg navbar-dark bg-success">
    <div class="container">
        <a class="navbar-brand fw-bold d-flex align-items-center" href="/">
            <img src="/uploads/logo-taveja.png" alt="Logo TAVEJA" height="40" class="me-2"> 
            TAVEJA
        </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav ms-auto align-items-center">
          <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
          <li class="nav-item"><a class="nav-link" href="/anggota">Anggota</a></li>
          <li class="nav-item"><a class="nav-link active" href="/struktur">Pengurus</a></li>
          <li class="nav-item"><a class="nav-link" href="/jadwal">Jadwal</a></li>
          <li class="nav-item"><a class="nav-link" href="/kegiatan">Kegiatan</a></li>
          <li class="nav-item"><a class="nav-link" href="/prestasi">Prestasi</a></li>
          
          <!-- MENU ANGGOTA -->
          <li class="nav-item ms-2">
            <% if (typeof user !== 'undefined' && user.isLoggedIn) { %>
              <div class="dropdown">
                <button class="btn btn-light dropdown-toggle btn-sm" type="button" data-bs-toggle="dropdown">
                  <i class="bi bi-person-circle me-1"></i><%= user.anggotaNama %>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                  <li><a class="dropdown-item" href="/kegiatan">Kegiatan</a></li>
                  <li><hr class="dropdown-divider"></li>
                  <li><a class="dropdown-item text-danger" href="/logout">Logout</a></li>
                </ul>
              </div>
            <% } else { %>
              <a href="/login" class="btn btn-light text-success btn-sm fw-bold">
                <i class="bi bi-box-arrow-in-right me-1"></i>Login Anggota
              </a>
            <% } %>
          </li>
          
          <!-- Login Admin -->
          <li class="nav-item ms-2">
            <a href="/login" class="btn btn-outline-light btn-sm">Login</a>
          </li>
        </ul>
      </div>
    </div>
  </nav>

  <!-- Content -->
  <div class="container py-5">
    <div class="text-center mb-5">
      <h2 class="fw-bold text-success">👥 Struktur Organisasi</h2>
      <p class="text-muted">Pengurus UKM Taekwondo UPNVJ Periode Aktif</p>
    </div>

    <% if (typeof pengurus !== 'undefined' && pengurus.length > 0) { %>
      <div class="row g-4 justify-content-center">
        <% pengurus.forEach(p => { %>
          <div class="col-md-6 col-lg-3">
            <div class="card h-100 border-0 shadow-sm pengurus-card text-center p-3">
              
              <!-- Foto Pengurus -->
              <div class="mx-auto mb-3">
                <% 
                  // Logic menentukan path foto
                  var fotoPath = p.foto ? '/uploads/struktur/' + p.foto : '/uploads/struktur/default.png';
                %>
                <img 
                  src="<%= fotoPath %>" 
                  class="pengurus-img" 
                  alt="<%= p.anggotaStruktur?.nama || 'Pengurus' %>"
                  onerror="this.src='https://ui-avatars.com/api/?name=<%= encodeURIComponent(p.anggotaStruktur?.nama || 'Pengurus') %>&background=064e3b&color=fff&size=120'"
                >
              </div>

              <!-- Nama & Jabatan -->
              <h5 class="fw-bold mb-1">
                <%= p.anggotaStruktur?.nama || 'Nama Tidak Tersedia' %>
              </h5>
              
              <!-- NIM (Opsional) -->
              <% if (p.anggotaStruktur?.nim) { %>
                <small class="text-muted d-block mb-2"><%= p.anggotaStruktur.nim %></small>
              <% } %>

              <span class="badge bg-success mb-2"><%= p.jabatan %></span>
              <p class="text-muted small mb-0">
                <i class="bi bi-calendar3 me-1"></i>Periode <%= p.periode %>
              </p>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <div class="text-center py-5">
        <i class="bi bi-people display-1 text-muted"></i>
        <h4 class="mt-3 text-muted">Data Pengurus Belum Tersedia</h4>
        <p class="text-muted">Silakan hubungi admin untuk menambahkan data pengurus</p>
      </div>
    <% } %>
  </div>

  <!-- Footer -->
  <footer class="bg-dark text-white text-center py-3 mt-auto">
    <small>© <%= new Date().getFullYear() %> UKM Taekwondo UPN Veteran Jakarta</small>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>