<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Edit Pengurus - Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <nav class="navbar navbar-dark bg-success mb-4">
    <div class="container-fluid"><span class="navbar-brand">UKM Taekwondo Admin</span></div>
  </nav>
  <div class="container">
    <h3 class="mb-4">Edit Pengurus Organisasi</h3>
    <% if (typeof error_msg !== 'undefined' && error_msg) { %><div class="alert alert-danger"><%= error_msg %></div><% } %>
    <div class="card shadow-sm">
      <div class="card-body">
        <form action="/struktur/admin/edit/<%= pengurus.id_struktur %>" method="POST" enctype="multipart/form-data">
          <div class="mb-3">
            <label>Pilih Anggota</label>
            <select name="id_anggota" class="form-select" required>
              <% anggota.forEach(a => { %>
                <option value="<%= a.id_anggota %>" <%= pengurus.id_anggota === a.id_anggota ? 'selected' : '' %>><%= a.nama %></option>
              <% }) %>
            </select>
          </div>
          <div class="mb-3"><label>Jabatan</label><input type="text" name="jabatan" class="form-control" value="<%= pengurus.jabatan %>" required></div>
          <div class="mb-3"><label>Periode</label><input type="text" name="periode" class="form-control" value="<%= pengurus.periode %>" required></div>
          <div class="mb-3">
            <label>Foto Saat Ini</label><br>
            <img src="/uploads/struktur/<%= pengurus.foto %>" width="80" class="rounded mb-2">
            <input type="file" name="foto" class="form-control" accept="image/*">
            <small class="text-muted">Kosongkan jika tidak ingin mengganti foto</small>
          </div>
          <button type="submit" class="btn btn-warning">Update Data</button>
          <a href="/struktur/admin" class="btn btn-secondary">Kembali</a>
        </form>
      </div>
    </div>
  </div>
</body>
</html>