<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Tambah Pengurus - Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <nav class="navbar navbar-dark bg-success mb-4">
    <div class="container-fluid"><span class="navbar-brand">UKM Taekwondo Admin</span></div>
  </nav>
  <div class="container">
    <h3 class="mb-4">Tambah Pengurus Organisasi</h3>
    <% if (typeof error_msg !== 'undefined' && error_msg) { %><div class="alert alert-danger"><%= error_msg %></div><% } %>
    <div class="card shadow-sm">
      <div class="card-body">
        <form action="/struktur/admin/tambah" method="POST" enctype="multipart/form-data">
          <div class="mb-3">
            <label>Pilih Anggota</label>
            <select name="id_anggota" class="form-select" required>
              <option value="">-- Pilih Anggota --</option>
              <% anggota.forEach(a => { %><option value="<%= a.id_anggota %>"><%= a.nama %> (<%= a.nim %>)</option><% }) %>
            </select>
          </div>
          <div class="mb-3"><label>Jabatan</label><input type="text" name="jabatan" class="form-control" placeholder="Contoh: Ketua Umum" required></div>
          <div class="mb-3"><label>Periode</label><input type="text" name="periode" class="form-control" placeholder="Contoh: 2024/2025" required></div>
          <div class="mb-3"><label>Foto Profil</label><input type="file" name="foto" class="form-control" accept="image/*"></div>
          <button type="submit" class="btn btn-primary">Simpan Data</button>
          <a href="/struktur/admin" class="btn btn-secondary">Kembali</a>
        </form>
      </div>
    </div>
  </div>
</body>
</html>