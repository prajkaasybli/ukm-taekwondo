<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Pendaftaran Kegiatan - Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <nav class="navbar navbar-dark bg-success mb-4">
    <div class="container-fluid">
      <span class="navbar-brand">UKM Taekwondo Admin</span>
      <a href="/admin/logout" class="btn btn-outline-light btn-sm">Logout</a>
    </div>
  </nav>

  <div class="container">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h3>📋 Pendaftaran: <%= kegiatan.nama_kegiatan %></h3>
        <p class="text-muted mb-0"><%= new Date(kegiatan.tanggal).toLocaleDateString('id-ID') %> | <%= kegiatan.lokasi %></p>
      </div>
      <div>
        <a href="/kegiatan/admin" class="btn btn-secondary btn-sm">← Kembali</a>
        <% if (kegiatan.link_pendaftaran) { %>
          <a href="<%= kegiatan.link_pendaftaran %>" target="_blank" class="btn btn-primary btn-sm ms-2">🔗 Link Pendaftaran</a>
        <% } %>
      </div>
    </div>

    <div class="card shadow-sm">
      <div class="card-body">
        <div class="alert alert-info">
          <strong>Total Pendaftar:</strong> <%= pendaftar.length %> orang
        </div>

        <% if (pendaftar.length > 0) { %>
          <table class="table table-striped">
            <thead class="table-success">
              <tr>
                <th>No</th><th>Nama</th><th>NIM</th><th>Jurusan</th><th>Angkatan</th><th>No. HP</th><th>Tanggal Daftar</th><th>Status</th>
              </tr>
            </thead>
            <tbody>
              <!-- Ubah p.anggota.nama menjadi p.anggotaPendaftar.nama -->
<% pendaftar.forEach(function(p, i) { %>
    <tr>
      <td><%= i + 1 %></td>
      <!-- ✅ PENTING: Gunakan nama alias yang baru -->
      <td><strong><%= p.anggotaDataPendaftar ? p.anggotaDataPendaftar.nama : 'Data Kosong' %></strong></td>
      <td><%= p.anggotaDataPendaftar ? p.anggotaDataPendaftar.nim : '-' %></td>
      <td><%= p.anggotaDataPendaftar ? p.anggotaDataPendaftar.jurusan : '-' %></td>
      <td><%= p.anggotaDataPendaftar ? p.anggotaDataPendaftar.angkatan : '-' %></td>
      <td><%= p.anggotaDataPendaftar ? p.anggotaDataPendaftar.no_hp : '-' %></td>
      <td><%= new Date(p.tanggal_daftar).toLocaleString('id-ID') %></td>
      <td><span class="badge bg-success"><%= p.status %></span></td>
    </tr>
    <% }) %>
            </tbody>
          </table>
        <% } else { %>
          <div class="text-center py-5">
            <i class="bi bi-inbox display-1 text-muted"></i>
            <h5 class="mt-3 text-muted">Belum ada pendaftar</h5>
          </div>
        <% } %>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>