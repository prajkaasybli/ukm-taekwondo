<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Tambah Prestasi - Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <nav class="navbar navbar-dark bg-success mb-4">
    <div class="container-fluid">
      <span class="navbar-brand">UKM Taekwondo Admin</span>
      <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
    </div>
  </nav>

  <div class="container">
    <h3 class="mb-4">🏆 Tambah Prestasi Baru</h3>
    
    <% if (typeof error_msg !== 'undefined' && error_msg) { %>
      <div class="alert alert-danger"><%= error_msg %></div>
    <% } %>
    
    <div class="card shadow-sm">
      <div class="card-body">
        <form action="/prestasi/admin/tambah" method="POST" enctype="multipart/form-data">
          
          <div class="mb-3">
            <label class="form-label fw-bold">Nama Kejuaraan</label>
            <input type="text" name="nama_kejuaraan" class="form-control" 
                   placeholder="Contoh: Kejuaraan Daerah DKI Jakarta" required>
          </div>

          <div class="mb-3">
            <label class="form-label fw-bold">Nama Anggota/Peserta</label>
            <select name="id_anggota" class="form-select" required>
              <option value="">-- Pilih Anggota --</option>
              <% if (typeof anggotaList !== 'undefined' && anggotaList.length > 0) { %>
                <% anggotaList.forEach(function(a) { %>
                  <option value="<%= a.id_anggota %>">
                    <%= a.nama %> - <%= a.nim %> (<%= a.jurusan %>)
                  </option>
                <% }) %>
              <% } else { %>
                <option value="" disabled>Tidak ada data anggota</option>
              <% } %>
            </select>
            <small class="text-muted">Pilih anggota yang meraih prestasi ini</small>
          </div>
        
          <div class="row">
            <div class="col-md-6 mb-3">
              <label class="form-label fw-bold">Tingkat</label>
              <select name="tingkat" class="form-select" required>
                <option value="">-- Pilih Tingkat --</option>
                <option value="Kota">Kota</option>
                <option value="Provinsi">Provinsi</option>
                <option value="Regional">Regional</option>
                <option value="Nasional">Nasional</option>
                <option value="Internasional">Internasional</option>
              </select>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label fw-bold">Tahun</label>
              <input type="number" name="tahun" class="form-control" 
                     value="<%= new Date().getFullYear() %>" 
                     min="2020" max="2030" required>
            </div>
          </div>
        
          <div class="mb-3">
            <label class="form-label fw-bold">Perolehan Juara</label>
            <select name="juara" class="form-select" required>
              <option value="">-- Pilih Peringkat --</option>
              <option value="Juara 1">Juara 1 🥇</option>
              <option value="Juara 2">Juara 2 🥈</option>
              <option value="Juara 3">Juara 3 🥉</option>
              <option value="Harapan 1">Harapan 1</option>
              <option value="Harapan 2">Harapan 2</option>
              <option value="Harapan 3">Harapan 3</option>
            </select>
          </div>
        
          <div class="mb-3">
            <label class="form-label fw-bold">Deskripsi</label>
            <textarea name="deskripsi" class="form-control" rows="3" 
                      placeholder="Deskripsi pencapaian..."></textarea>
          </div>
        
          <div class="mb-3">
            <label class="form-label fw-bold">Foto Juara</label>
            <input type="file" name="foto" class="form-control" accept="image/*">
            <small class="text-muted">Upload foto saat memegang medali/piala (JPG/PNG - Max 5MB)</small>
          </div>
        
          <div class="d-flex gap-2 mt-4">
            <button type="submit" class="btn btn-success px-4">💾 Simpan Prestasi</button>
            <a href="/prestasi/admin" class="btn btn-secondary">↩️ Batal</a>
          </div>
        </form>
      </div>
    </div>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>