<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <title>Tambah Jadwal - Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <nav class="navbar navbar-dark bg-success mb-4">
    <div class="container-fluid">
      <span class="navbar-brand">UKM Taekwondo Admin</span>
      <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
    </div>
  </nav>

  <div class="container">
    <div class="row justify-content-center">
      <div class="col-md-8">
        <div class="card shadow-sm">
          <div class="card-header bg-success text-white">
            <h4 class="mb-0">➕ Tambah Jadwal Latihan</h4>
          </div>
          <div class="card-body p-4">
            <% if (typeof error_msg !== 'undefined' && error_msg) { %>
              <div class="alert alert-danger"><%= error_msg %></div>
            <% } %>

            <form action="/jadwal/admin/tambah" method="POST">
              <div class="mb-3">
                <label class="form-label fw-bold">Hari Latihan</label>
                <select name="hari" class="form-select" required>
                  <option value="">-- Pilih Hari --</option>
                  <option value="Senin">Senin</option>
                  <option value="Selasa">Selasa</option>
                  <option value="Rabu">Rabu</option>
                  <option value="Kamis">Kamis</option>
                  <option value="Jumat">Jumat</option>
                  <option value="Sabtu">Sabtu</option>
                  <option value="Minggu">Minggu</option>
                </select>
              </div>

              <div class="mb-3">
                <label class="form-label fw-bold">Waktu</label>
                <input type="text" name="waktu" class="form-control" placeholder="Contoh: 16:00 - 18:00" required>
                <small class="text-muted">Format: HH:MM - HH:MM</small>
              </div>

              <div class="mb-3">
                <label class="form-label fw-bold">Lokasi</label>
                <input type="text" name="lokasi" class="form-control" placeholder="Contoh: Gedung Sudirman Lt. 4" required>
              </div>

              <div class="mb-4">
                <label class="form-label fw-bold">Keterangan</label>
                <textarea name="keterangan" class="form-control" rows="3" placeholder="Catatan tambahan (opsional)"></textarea>
              </div>

              <div class="d-flex gap-2">
                <button type="submit" class="btn btn-success px-4">💾 Simpan Jadwal</button>
                <a href="/jadwal/admin" class="btn btn-secondary">↩️ Batal</a>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>